{
  "expo": {
    "name": "Vaulta",
    "slug": "cash-books-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.books.cashbooks",
      "entitlements": {
        "com.apple.developer.applesignin": false
      }
    },
    "android": {
      "package": "com.anonymous.cashbooksmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Vaulta",
      "shortName": "Vaulta",
      "description": "Vaulta web app",
      "themeColor": "#141c2d",
      "backgroundColor": "#141c2d",
      "display": "standalone",
      "meta": {
        "viewport": "width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no"
      }
    }
  }
}
